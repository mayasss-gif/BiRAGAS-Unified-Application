/*
 * Override the multi-line process.shell directive from nf-core/crisprseq 2.3.0
 * which is incompatible with Nextflow >= 25.x and causes:
 *   /bin/bash: line 10: .command.run: Permission denied
 */
process.shell = ['/bin/bash', '-euo', 'pipefail']

/*
 * The CRISPRSEQ_PLOTTER Singularity container has two issues:
 *
 *   A) ggplot2 < 3.5.2 — known bug in expand_limits that crashes ggsave()
 *   B) ggseqlogo — crashes with "subscript out of bounds" when substitution
 *      data produces a matrix with zero columns
 *
 * Fix strategy (works with read-only Singularity containers):
 *
 *   1. beforeScript (runs ON THE HOST) uses `singularity exec` against the
 *      cached plotter container to install a patched ggplot2 into a
 *      persistent host directory (~/.nxf_r_patched_libs/).
 *
 *   2. containerOptions:
 *      - Bind-mounts the patched R library and sets R_LIBS_USER via --env
 *        (survives Nextflow's `env -` variable stripping).
 *      - Bind-mounts plotter_patch.R as /.Rprofile inside the container.
 *        Since nf-core sets R_PROFILE_USER=/.Rprofile, R reads our patch
 *        on startup.  The patch wraps ggseqlogo and ggsave with tryCatch
 *        so the plotter script continues past edge-case data.
 *      - Sets FONTCONFIG_PATH=/tmp to avoid "No writable cache" warnings.
 *
 *   3. errorStrategy 'ignore' as a final safety net.
 */

def home       = System.getenv('HOME')
def rlib       = "${home}/.nxf_r_patched_libs"
def singCache  = "${home}/nxf_singularity_cache"
def patchFile  = System.getenv('PLOTTER_PATCH_R') ?: "${home}/plotter_patch.R"

process {
    withName: 'CRISPRSEQ_PLOTTER' {
        beforeScript = """
            if [ ! -f ${rlib}/.done ]; then
                mkdir -p ${rlib} 2>/dev/null || true
                IMG=\$(ls ${singCache}/*mulled-v2-6de07928* 2>/dev/null | head -1)
                if [ -n "\$IMG" ]; then
                    SING=\$(command -v singularity || command -v apptainer || echo "")
                    if [ -n "\$SING" ]; then
                        \$SING exec -B ${rlib}:${rlib} "\$IMG" \\
                            R --no-save --no-restore -e "install.packages('ggplot2', repos='https://cloud.r-project.org', lib='${rlib}')" \\
                            && touch ${rlib}/.done || true
                    fi
                fi
            fi
        """.stripIndent().trim()

        containerOptions = "-B ${rlib}:${rlib} -B ${patchFile}:/.Rprofile --env R_LIBS_USER=${rlib} --env FONTCONFIG_PATH=/tmp"
        errorStrategy    = 'ignore'
    }
}
